<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Selector with Color Change</title>
</head>
<body>
  <h1 id="title">Hello SVPCET Students</h1>
  <p class="message">This is Dept of CAI</p>
  <p>This is 3rd year V Sem.</p>

  <button onclick="selectElement()">Click Me</button>

  <script>
    function selectElement() {
      // Change the title color
      let title = document.getElementById("title");
      title.style.color = "green";

      // Change background color of all paragraphs
      let paragraphs = document.getElementsByTagName("p");
      for (let i = 0; i < paragraphs.length; i++) {
        paragraphs[i].style.backgroundColor = "yellow";
      }
    }
  </script>
</body>
</html>
